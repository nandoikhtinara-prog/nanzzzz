<script>
    function addPhoto() {
        const urlInput = document.getElementById('imageUrl');
        const gallery = document.querySelector('.gallery');

        if (urlInput.value.trim() === "") {
            alert("Harap masukkan link gambar terlebih dahulu!");
            return;
        }

        // Membuat elemen div baru untuk foto
        const newItem = document.createElement('div');
        newItem.className = 'gallery-item';

        // Mengisi div dengan tag img
        newItem.innerHTML = `<img src="${urlInput.value}" alt="Maxwell Salvador Baru">`;

        // Menambahkan ke galeri (di urutan paling depan)
        gallery.prepend(newItem);

        // Reset input
        urlInput.value = "";
        alert("Foto berhasil ditambahkan ke tampilan!");
    }
</script>
